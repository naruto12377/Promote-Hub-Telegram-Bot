# ╔════════════════════════════════════════════════════════╗
# ║          PromoteHub — Environment Variables            ║
# ║  Copy this to .env and fill in your values             ║
# ╚════════════════════════════════════════════════════════╝

# ── Required ──────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=@YourBotUsername

# Get these IDs by forwarding a message from each chat to @userinfobot
PROMOTION_CHANNEL_ID=-100xxxxxxxxxx
PROMOTION_CHANNEL_LINK=https://t.me/YourChannel

GROUP_ID=-100xxxxxxxxxx
GROUP_LINK=https://t.me/YourGroup

# A PRIVATE channel only your bot can access — used as database
DATABASE_CHANNEL_ID=-100xxxxxxxxxx

# Your Telegram user ID (comma-separated for multiple admins)
ADMIN_IDS=123456789

# ── Posting Rules ─────────────────────────────────────────
# How many posts a user can submit per hour
POSTS_PER_HOUR=2

# How many warnings before auto-ban
MAX_WARNINGS=3

# Where is /post allowed?
# Options: dm | group | both
#   dm    → users submit only in bot private messages (recommended)
#   group → users submit only inside the group (bot forwards to DM)
#   both  → accepted in both places
POST_ALLOWED_IN=dm

# ── Content Filter ────────────────────────────────────────
BAD_WORDS=spam,scam,fake,adult,xxx,porn,crypto scam,ponzi,betting,gambling,hack,phishing
BAD_LINKS=onlyfans.com,bit.ly/adult,t.me/joinchat/adult

# ── Render ────────────────────────────────────────────────
PORT=8080
